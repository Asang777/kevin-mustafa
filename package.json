{
  "name": "kevin-mustafa-com",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "High-performance personal profile website built with Astro for strong SEO, UX, and Core Web Vitals.",
  "author": "Kevin Mustafa",
  "license": "MIT",
  "keywords": [
    "astro",
    "portfolio",
    "personal-website",
    "seo",
    "core-web-vitals",
    "performance"
  ],
  "engines": {
    "node": ">=18.17.0"
  },
  "scripts": {
    "dev": "astro dev --host 0.0.0.0 --port 4321",
    "start": "astro dev --host 0.0.0.0 --port 4321",
    "build": "astro build",
    "build:strict": "astro check && astro build",
    "preview": "astro preview --host 0.0.0.0 --port 4321",
    "check": "astro check",
    "format": "prettier --write ."
  },
  "dependencies": {
    "astro": "4.16.0"
  },
  "devDependencies": {
    "prettier": "3.3.3",
    "prettier-plugin-astro": "0.14.0",
    "typescript": "5.6.2"
  }
