---
const year = new Date().getFullYear();
---

<footer class="site-footer" aria-label="Site footer">
  <div class="footer-inner">
    <p class="copyright">© {year} Kevin Mustafa. All rights reserved.</p>
    <a class="sitemap-link" href="/sitemap.xml" rel="noopener">Sitemap</a>
  </div>
</footer>

<style>
  .site-footer {
    border-top: 1px solid var(--line, #e5e7eb);
    padding: 1rem 0 1.5rem;
    margin-top: 2rem;
  }

  .footer-inner {
    width: min(100% - 2rem, 72rem);
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
    flex-wrap: wrap;
  }

  .copyright {
    margin: 0;
    font-size: 0.9rem;
    color: var(--text-muted, #6b7280);
  }

  .sitemap-link {
    font-size: 0.9rem;
    font-weight: 600;
    text-decoration: none;
    color: var(--primary, #2563eb);
  }

  .sitemap-link:hover {
    text-decoration: underline;
  }

  .sitemap-link:focus-visible {
    outline: 2px solid var(--primary, #2563eb);
    outline-offset: 2px;
    border-radius: 4px;
  }
</style>
