---
export interface Props {
  title?: string;
  description?: string;
  image?: string;
  imageAlt?: string;
  type?: "website" | "article" | "profile";
  noindex?: boolean;
  publishedTime?: string;
  modifiedTime?: string;
  keywords?: string[];
  locale?: string;
  alternates?: Array<{
    hreflang: string;
    href: string;
  }>;
  preconnectOrigins?: string[];
  preloadImages?: string[];
}

const {
  title = "Kevin Mustafa | IT Specialist, Fullstack Developer, and DevOps Engineer",
  description = "Kevin Mustafa is an IT specialist focused on fullstack web development, cloud infrastructure, and DevOps engineering.",
  image = "/og-image.png",
  imageAlt = "Kevin Mustafa — Fullstack Developer & DevOps Engineer",
  type = "website",
  noindex = false,
  publishedTime,
  modifiedTime,
  keywords = [],
  locale = "en_US",
  alternates = [],
  preconnectOrigins = ["https://fonts.googleapis.com", "https://fonts.gstatic.com"],
  preloadImages = ["/images/kevin-mustafa.webp"],
} = Astro.props;

const site = Astro.site ?? new URL("https://kevin-mustafa.com");
const canonicalUrl = new URL(`${Astro.url.pathname}${Astro.url.search}`, site).toString();
const ogImage = image.startsWith("http") ? image : new URL(image, site).toString();
const ogImageType = ogImage.endsWith(".png")
  ? "image/png"
  : ogImage.endsWith(".jpg") || ogImage.endsWith(".jpeg")
    ? "image/jpeg"
    : ogImage.endsWith(".webp")
      ? "image/webp"
      : "image/svg+xml";

const pageTitle = title.includes("Kevin Mustafa") ? title : `${title} | Kevin Mustafa`;
const robots = noindex
  ? "noindex, nofollow, noarchive"
  : "index, follow, max-snippet:-1, max-image-preview:large, max-video-preview:-1";

const defaultKeywords = [
  "Kevin Mustafa",
  "IT Specialist",
  "Fullstack Developer",
  "DevOps Engineer",
  "AWS Cloud Infrastructure",
  "Web Performance",
  "SEO",
];
const mergedKeywords = [...new Set([...defaultKeywords, ...keywords])];
const languageAlternates =
  alternates.length > 0
    ? alternates
    : [
        { hreflang: "en", href: canonicalUrl },
        { hreflang: "x-default", href: canonicalUrl },
      ];
const ogLocale = locale.replace("-", "_");
const ogLocaleAlternates = [...new Set(
  languageAlternates
    .map((alternate) => alternate.hreflang)
    .filter((lang) => lang.toLowerCase() !== "x-default")
    .map((lang) => lang.replace("-", "_"))
    .filter((lang) => lang !== ogLocale)
)];
const preconnectList = [...new Set(preconnectOrigins)];
const preloadImageList = [...new Set(preloadImages)];

const jsonLd = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Person",
      "@id": `${site.toString()}#person`,
      name: "Kevin Mustafa",
      jobTitle: "IT Specialist",
      url: site.toString(),
      image: ogImage,
      email: "mailto:kevinmustafa1993@gmail.com",
      sameAs: [],
      knowsAbout: [
        "Fullstack Development",
        "DevOps",
        "AWS Cloud Infrastructure",
        "Web Performance",
        "SEO",
      ],
    },
    {
      "@type": "Organization",
      "@id": "https://siberind.com/#organization",
      name: "Siberind",
      url: "https://siberind.com",
      logo: new URL("/og-image.png", site).toString(),
      sameAs: ["https://siberind.com"],
    },
    {
      "@type": "WebSite",
      "@id": `${site.toString()}#website`,
      url: site.toString(),
      name: "Kevin Mustafa",
      description,
      keywords: mergedKeywords,
      inLanguage: "en",
      publisher: {
        "@id": `${site.toString()}#person`,
      },
    },
    {
      "@type": "WebPage",
      "@id": `${canonicalUrl}#webpage`,
      url: canonicalUrl,
      name: pageTitle,
      description,
      keywords: mergedKeywords,
      isPartOf: {
        "@id": `${site.toString()}#website`,
      },
      about: {
        "@id": `${site.toString()}#person`,
      },
      mentions: [
        {
          "@id": "https://siberind.com/#organization",
        },
      ],
      primaryImageOfPage: {
        "@type": "ImageObject",
        url: ogImage,
      },
      datePublished: publishedTime,
      dateModified: modifiedTime ?? publishedTime,
      inLanguage: "en",
    },
  ],
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    {mergedKeywords.length > 0 && <meta name="keywords" content={mergedKeywords.join(", ")} />}
    <meta name="robots" content={robots} />
    <meta name="theme-color" content="#0b1220" />
    <meta name="author" content="Kevin Mustafa" />

    <title>{pageTitle}</title>
    <link rel="canonical" href={canonicalUrl} />
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="shortcut icon" href="/favicon.ico" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="icon" href="/apple-touch-icon.png" type="image/png" sizes="180x180" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" sizes="180x180" />
    <link rel="manifest" href="/site.webmanifest" />
    {
      preconnectList.map((origin) => (
        <link rel="dns-prefetch" href={origin} />
      ))
    }
    {
      preconnectList.map((origin) => (
        <link rel="preconnect" href={origin} crossorigin />
      ))
    }
    {
      preloadImageList.map((href, index) => (
        <link rel="preload" as="image" href={href} fetchpriority={index === 0 ? "high" : "auto"} />
      ))
    }
    {
      languageAlternates.map((alternate) => (
        <link rel="alternate" hreflang={alternate.hreflang} href={alternate.href} />
      ))
    }

    <meta property="og:site_name" content="Kevin Mustafa" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={type} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:alt" content={imageAlt} />
    <meta property="og:image:type" content={ogImageType} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:locale" content={ogLocale} />
    {
      ogLocaleAlternates.map((localeAlt) => (
        <meta property="og:locale:alternate" content={localeAlt} />
      ))
    }

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <meta name="twitter:image:alt" content={imageAlt} />
    <meta name="twitter:url" content={canonicalUrl} />

    {publishedTime && <meta property="article:published_time" content={publishedTime} />}
    {modifiedTime && <meta property="article:modified_time" content={modifiedTime} />}
    {modifiedTime && <meta property="og:updated_time" content={modifiedTime} />}

    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  </head>
  <body>
    <a class="skip-link" href="#main-content">Skip to main content</a>
    <slot name="header" />
    <main id="main-content">
      <slot />
    </main>
    <slot name="footer" />
  </body>
</html>

<style is:global>
  :root {
    color-scheme: light dark;
  }

  html,
  body {
    margin: 0;
    padding: 0;
    min-height: 100%;
    text-rendering: optimizeLegibility;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
  }

  .skip-link {
    position: absolute;
    left: -9999px;
    top: 0;
    z-index: 1000;
    background: #ffffff;
    color: #0b1220;
    border: 2px solid #0b1220;
    border-radius: 8px;
    padding: 0.5rem 0.75rem;
    font-weight: 600;
  }

  .skip-link:focus {
    left: 0.75rem;
    top: 0.75rem;
  }
</style>
