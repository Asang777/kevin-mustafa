---
import BaseLayout from "../layouts/BaseLayout.astro";
import SiteHeader from "../components/SiteHeader.astro";
import SiteFooter from "../components/SiteFooter.astro";
import ExperienceTimeline from "../components/ExperienceTimeline.astro";
import profile from "../data/profile";
import "../styles/global.css";

const pageTitle = "Kevin Mustafa | Fullstack Developer & DevOps Engineer";
const pageDescription =
  "Explore Kevin Mustafa's profile, real projects, delivery approach, and expertise in fullstack engineering, DevOps, and AWS cloud infrastructure.";
const publishedTime = "2024-08-01T00:00:00.000Z";
const modifiedTime = new Date().toISOString();

const seoAlternates = [
  { hreflang: "en", href: "https://kevin-mustafa.com/" },
  { hreflang: "x-default", href: "https://kevin-mustafa.com/" },
];

const uniqueTechnologies = [...new Set(profile.experience.flatMap((item) => item.technologies))];

const heroStats = [
  { value: profile.experience.length, suffix: "", label: "Professional Roles" },
  { value: uniqueTechnologies.length, suffix: "+", label: "Technologies" },
  { value: profile.education.length, suffix: "", label: "Academic Degrees" },
];

const valuePropositions = [
  {
    title: "Product + Infrastructure Mindset",
    description:
      "You get one engineer who can ship product features while keeping systems stable, scalable, and cost-efficient.",
  },
  {
    title: "Execution Speed with Reliability",
    description:
      "From architecture to deployment, every phase is designed for maintainability, observability, and long-term growth.",
  },
  {
    title: "Business-Focused Engineering",
    description:
      "Technical decisions are aligned with outcomes: faster releases, better user experience, and reduced operational risk.",
  },
];

const projectList = [...profile.featuredProjects];
const hasSiberind = projectList.some((p) => (p.link || "").includes("siberind.com"));
if (!hasSiberind) {
  projectList.unshift({
    name: "Siberind",
    tagline: "Digital presence and technology solutions platform",
    summary:
      "Built and launched Siberind as a conversion-oriented company profile and lead generation website.",
    impact:
      "Improved trust, discoverability, and client inquiry flow through better UX, messaging clarity, and technical SEO.",
    role: "Fullstack Developer & DevOps Engineer",
    stack: ["Astro", "TypeScript", "SEO", "Docker", "Nginx"],
    link: "https://siberind.com",
  });
}

const processSteps = [
  {
    title: "1. Discovery & Scope",
    detail:
      "Clarify goals, constraints, timeline, and success metrics to ensure architecture aligns with business outcomes.",
  },
  {
    title: "2. Build & Validate",
    detail:
      "Develop with clean structure, performance-first implementation, and iterative validation against real use cases.",
  },
  {
    title: "3. Deploy & Optimize",
    detail:
      "Ship through repeatable pipelines, monitor behavior, and continuously optimize reliability and user experience.",
  },
];

const faqItems = [
  {
    q: "What kind of projects can Kevin help with?",
    a: "Web platforms, dashboards, fullstack product development, and cloud infrastructure improvement using practical engineering strategies.",
  },
  {
    q: "Is Kevin available for remote work?",
    a: "Yes. Kevin is open to remote and freelance opportunities with teams that value ownership, quality, and delivery speed.",
  },
  {
    q: "How does Kevin approach SEO and performance?",
    a: "By prioritizing semantic structure, content clarity, technical metadata, accessibility, and Core Web Vitals from the foundation.",
  },
];

const faqJsonLd = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: faqItems.map((item) => ({
    "@type": "Question",
    name: item.q,
    acceptedAnswer: {
      "@type": "Answer",
      text: item.a,
    },
  })),
};

const projectsJsonLd = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  name: "Kevin Mustafa Projects",
  itemListElement: projectList.map((project, index) => ({
    "@type": "ListItem",
    position: index + 1,
    item: {
      "@type": "CreativeWork",
      name: project.name,
      description: `${project.tagline}. ${project.summary} ${project.impact}`,
      url: project.link ?? "https://kevin-mustafa.com/#contact",
      creator: {
        "@type": "Person",
        name: profile.identity.fullName,
        url: "https://kevin-mustafa.com/",
      },
      keywords: project.stack.join(", "),
    },
  })),
};
---

<BaseLayout
  title={pageTitle}
  description={pageDescription}
  image="/og-image.png"
  imageAlt="Kevin Mustafa — Fullstack Developer & DevOps Engineer"
  type="profile"
  publishedTime={publishedTime}
  modifiedTime={modifiedTime}
  keywords={[...profile.seo.keywords, "portfolio projects", "Siberind", "siberind.com"]}
  alternates={seoAlternates}
>
  <SiteHeader slot="header" />

  <div id="top" class="page">
    <section class="container hero" id="about" aria-labelledby="hero-title">
      <article class="card hero-content reveal" data-reveal>
        <p class="eyebrow">{profile.identity.location}</p>
        <h1 id="hero-title">{profile.identity.headline}</h1>
        <p class="intro">{profile.summary}</p>

        <div class="cluster actions">
          <a class="button button-primary" href={`mailto:${profile.identity.email}`}>Email Kevin</a>
          <a class="button button-secondary" href="#projects">View Projects</a>
        </div>

        <ul class="stat-grid" aria-label="Profile highlights">
          {
            heroStats.map((stat, index) => (
              <li class="card stat reveal" data-reveal style={`--reveal-delay: ${(index + 1) * 40}ms;`}>
                <strong>
                  <span data-counter data-target={String(stat.value)} data-suffix={stat.suffix}>0</span>
                </strong>
                <span>{stat.label}</span>
              </li>
            ))
          }
        </ul>
      </article>

      <aside class="card profile-aside reveal" data-reveal style="--reveal-delay: 80ms;" aria-label="Contact summary">
        <img
          src={profile.identity.avatar}
          alt={`Portrait of ${profile.identity.fullName}`}
          width="400"
          height="400"
          loading="eager"
          fetchpriority="high"
          decoding="async"
          class="avatar"
        />
        <h2>{profile.identity.fullName}</h2>
        <p>{profile.identity.availability}</p>
        <ul class="contact-list">
          {
            profile.contacts.map((contact) => (
              <li>
                <span>{contact.label}</span>
                {contact.href ? <a href={contact.href}>{contact.value}</a> : <strong>{contact.value}</strong>}
              </li>
            ))
          }
        </ul>
      </aside>
    </section>

    <section class="container section stack" aria-labelledby="value-title">
      <h2 id="value-title" class="reveal" data-reveal>Why Work With Kevin</h2>
      <div class="value-grid">
        {
          valuePropositions.map((item, index) => (
            <article class="card value-card reveal" data-reveal style={`--reveal-delay: ${(index + 1) * 60}ms;`}>
              <h3>{item.title}</h3>
              <p>{item.description}</p>
            </article>
          ))
        }
      </div>
    </section>

    <section class="container section stack" id="projects" aria-labelledby="projects-title">
      <div class="cluster projects-heading-row">
        <h2 id="projects-title" class="reveal" data-reveal>Real Projects</h2>
        <span class="tag reveal" data-reveal style="--reveal-delay: 40ms;">{projectList.length} published entries</span>
      </div>

      <p class="section-lead reveal" data-reveal style="--reveal-delay: 60ms;">
        Selected work focused on outcomes: performance, reliability, visibility, and business impact.
      </p>

      <div class="projects-grid">
        {
          projectList.map((project, index) => {
            const isExternal = Boolean(project.link && project.link.startsWith("http"));
            const href = project.link ?? "#contact";
            const isSiberind = href.includes("siberind.com");
            const backlinkRel = isSiberind
              ? "noopener noreferrer external me"
              : isExternal
                ? "noopener noreferrer external"
                : undefined;

            return (
              <article
                class={`card project-card project-card-interactive reveal ${isSiberind ? "project-siberind" : ""}`}
                data-reveal
                style={`--reveal-delay: ${(index + 1) * 70}ms;`}
                data-project-card
              >
                <header class="project-header">
                  <p class="project-eyebrow">{project.role}</p>
                  <h3>{project.name}</h3>
                  <p class="project-tagline">{project.tagline}</p>
                </header>

                <p>{project.summary}</p>
                <p class="project-impact"><strong>Impact:</strong> {project.impact}</p>

                <ul class="cluster tech-list" aria-label={`${project.name} technology stack`}>
                  {project.stack.map((tech) => <li class="tag">{tech}</li>)}
                </ul>

                <a
                  class="project-link"
                  href={href}
                  target={isExternal ? "_blank" : undefined}
                  rel={backlinkRel}
                  title={isSiberind ? "Siberind official website" : undefined}
                >
                  {isSiberind ? "Visit Siberind (Live Website) ↗" : "Explore Project ↗"}
                </a>
              </article>
            );
          })
        }
      </div>
    </section>

    <section class="container section stack" aria-labelledby="process-title">
      <h2 id="process-title" class="reveal" data-reveal>Delivery Process</h2>
      <ol class="process-grid">
        {
          processSteps.map((step, index) => (
            <li class="card process-item reveal" data-reveal style={`--reveal-delay: ${(index + 1) * 70}ms;`}>
              <h3>{step.title}</h3>
              <p>{step.detail}</p>
            </li>
          ))
        }
      </ol>
    </section>

    <section class="container section stack" aria-labelledby="strengths-title">
      <h2 id="strengths-title" class="reveal" data-reveal>Core Strengths</h2>
      <ul class="tag-list reveal" data-reveal style="--reveal-delay: 40ms;">
        {profile.coreStrengths.map((strength) => <li class="tag">{strength}</li>)}
      </ul>
    </section>

    <div class="container section reveal timeline-shell" data-reveal>
      <div class="timeline-progress" aria-hidden="true">
        <span class="timeline-progress-fill"></span>
      </div>
      <ExperienceTimeline id="experience" heading="Experience" items={profile.experience} />
    </div>

    <section class="container section stack" id="skills" aria-labelledby="skills-title">
      <h2 id="skills-title" class="reveal" data-reveal>Skills</h2>
      <div class="skills-grid">
        {
          profile.skills.map((group, index) => (
            <article class="card reveal" data-reveal style={`--reveal-delay: ${(index + 1) * 45}ms;`}>
              <h3>{group.category}</h3>
              <ul class="skill-list">
                {group.skills.map((skill) => <li>{skill}</li>)}
              </ul>
            </article>
          ))
        }
      </div>
    </section>

    <section class="container section stack" id="education" aria-labelledby="education-title">
      <h2 id="education-title" class="reveal" data-reveal>Education</h2>
      <div class="education-grid">
        {
          profile.education.map((item, index) => (
            <article class="card reveal" data-reveal style={`--reveal-delay: ${(index + 1) * 70}ms;`}>
              <h3>{item.degree}</h3>
              <p>{item.institution}</p>
              <p><small>Graduated {item.graduationYear}</small></p>
            </article>
          ))
        }
      </div>
    </section>

    <section class="container section stack" id="faq" aria-labelledby="faq-title">
      <h2 id="faq-title" class="reveal" data-reveal>Frequently Asked Questions</h2>
      <div class="faq-list">
        {
          faqItems.map((item, index) => (
            <details class="card faq-item reveal" data-reveal style={`--reveal-delay: ${(index + 1) * 60}ms;`}>
              <summary>{item.q}</summary>
              <p>{item.a}</p>
            </details>
          ))
        }
      </div>
    </section>

    <section class="container section stack contact-section" id="contact" aria-labelledby="contact-title">
      <h2 id="contact-title" class="reveal" data-reveal>Let’s Build Something Great</h2>
      <p class="reveal" data-reveal style="--reveal-delay: 30ms;">
        If you need an engineer who can build product features and maintain reliable infrastructure, you can reach Kevin directly.
      </p>

      <div class="cluster reveal" data-reveal style="--reveal-delay: 60ms;">
        <a class="button button-primary" href={`mailto:${profile.identity.email}`}>{profile.identity.email}</a>
        {
          profile.socials.map((social) => (
            <a class="button button-secondary" href={social.href} target="_blank" rel="noopener noreferrer">
              {social.platform}
            </a>
          ))
        }
      </div>
    </section>
  </div>

  <SiteFooter slot="footer" />

  <script type="application/ld+json" set:html={JSON.stringify(faqJsonLd)} />
  <script type="application/ld+json" set:html={JSON.stringify(projectsJsonLd)} />
</BaseLayout>

<script is:inline>
  if (typeof window !== "undefined") {
    const reduceMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

    // Reveal animations
    const revealElements = Array.from(document.querySelectorAll("[data-reveal]"));
    if (reduceMotion) {
      revealElements.forEach((el) => el.classList.add("is-visible"));
    } else if ("IntersectionObserver" in window) {
      const revealObserver = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add("is-visible");
              revealObserver.unobserve(entry.target);
            }
          });
        },
        { threshold: 0.14, rootMargin: "0px 0px -8% 0px" }
      );
      revealElements.forEach((el) => revealObserver.observe(el));
    } else {
      revealElements.forEach((el) => el.classList.add("is-visible"));
    }

    // Animated counters
    const counters = Array.from(document.querySelectorAll("[data-counter]"));
    const animateCounter = (el) => {
      const target = Number(el.getAttribute("data-target") || "0");
      const suffix = el.getAttribute("data-suffix") || "";
      if (Number.isNaN(target) || target < 0) return;

      const duration = 1200;
      const start = performance.now();

      const tick = (now) => {
        const progress = Math.min(1, (now - start) / duration);
        const eased = 1 - Math.pow(1 - progress, 3);
        const value = Math.round(target * eased);
        el.textContent = `${value}${suffix}`;

        if (progress < 1) requestAnimationFrame(tick);
        else el.textContent = `${target}${suffix}`;
      };

      requestAnimationFrame(tick);
    };

    if (counters.length > 0) {
      if (reduceMotion || !("IntersectionObserver" in window)) {
        counters.forEach((el) => {
          const target = el.getAttribute("data-target") || "0";
          const suffix = el.getAttribute("data-suffix") || "";
          el.textContent = `${target}${suffix}`;
        });
      } else {
        const counterObserver = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                animateCounter(entry.target);
                counterObserver.unobserve(entry.target);
              }
            });
          },
          { threshold: 0.4 }
        );
        counters.forEach((el) => counterObserver.observe(el));
      }
    }

    // Active section observer (scrollspy)
    const navLinks = Array.from(document.querySelectorAll(".site-header [data-nav-link]"));
    const sectionPairs = navLinks
      .map((link) => {
        const href = link.getAttribute("href");
        if (!href || !href.startsWith("#")) return null;
        const section = document.querySelector(href);
        if (!section) return null;
        return { href, section };
      })
      .filter(Boolean);

    const setActiveLink = (href) => {
      navLinks.forEach((link) => {
        const active = link.getAttribute("href") === href;
        link.classList.toggle("is-active", active);
        if (active) link.setAttribute("aria-current", "true");
        else link.removeAttribute("aria-current");
      });
    };

    if (sectionPairs.length > 0 && "IntersectionObserver" in window) {
      let currentHref = window.location.hash && window.location.hash !== "#" ? window.location.hash : sectionPairs[0].href;
      setActiveLink(currentHref);

      const sectionVisibility = new Map();
      const sectionObserver = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            sectionVisibility.set(entry.target.id, entry.intersectionRatio);
          });

          let bestHref = currentHref;
          let bestScore = -1;

          sectionPairs.forEach(({ href, section }) => {
            const score = sectionVisibility.get(section.id) || 0;
            if (score > bestScore) {
              bestScore = score;
              bestHref = href;
            }
          });

          if (bestHref !== currentHref) {
            currentHref = bestHref;
            setActiveLink(currentHref);
          }
        },
        { rootMargin: "-25% 0px -55% 0px", threshold: [0.15, 0.3, 0.5, 0.7] }
      );

      sectionPairs.forEach(({ section }) => sectionObserver.observe(section));
      window.addEventListener("hashchange", () => {
        if (window.location.hash) setActiveLink(window.location.hash);
      });
    }

    // Timeline progress indicator
    const timelineShell = document.querySelector(".timeline-shell");
    const timelineFill = document.querySelector(".timeline-progress-fill");

    if (timelineShell && timelineFill) {
      const updateTimelineProgress = () => {
        const rect = timelineShell.getBoundingClientRect();
        const vh = window.innerHeight || document.documentElement.clientHeight;
        const start = vh * 0.2;
        const end = rect.height - vh * 0.35;
        const raw = (start - rect.top) / Math.max(1, end);
        const progress = Math.min(1, Math.max(0, raw));
        timelineFill.style.transform = `scaleY(${progress})`;
      };

      updateTimelineProgress();
      window.addEventListener("scroll", updateTimelineProgress, { passive: true });
      window.addEventListener("resize", updateTimelineProgress);
    }

    // Subtle project card spotlight interaction
    const projectCards = Array.from(document.querySelectorAll("[data-project-card]"));
    if (!reduceMotion && projectCards.length > 0) {
      projectCards.forEach((card) => {
        card.addEventListener("pointermove", (event) => {
          const rect = card.getBoundingClientRect();
          const x = ((event.clientX - rect.left) / rect.width) * 100;
          const y = ((event.clientY - rect.top) / rect.height) * 100;
          card.style.setProperty("--spot-x", `${x}%`);
          card.style.setProperty("--spot-y", `${y}%`);
        });

        card.addEventListener("pointerleave", () => {
          card.style.setProperty("--spot-x", "50%");
          card.style.setProperty("--spot-y", "0%");
        });
      });
    }
  }
</script>

<style>
  .page {
    padding-block: var(--space-8) var(--space-12);
    background:
      radial-gradient(900px 350px at 10% -10%, color-mix(in oklab, var(--primary-soft), transparent 35%), transparent 70%),
      radial-gradient(900px 350px at 100% -10%, color-mix(in oklab, var(--primary-soft), transparent 45%), transparent 72%);
  }

  .section {
    margin-top: var(--space-12);
  }

  .section-lead {
    font-size: var(--text-md);
  }

  .hero {
    display: grid;
    grid-template-columns: 1.35fr 1fr;
    gap: var(--space-6);
    align-items: start;
  }

  .hero-content {
    padding: clamp(var(--space-5), 2.5vw, var(--space-8));
  }

  .eyebrow {
    font-weight: 700;
    color: var(--primary);
    margin-bottom: var(--space-2);
  }

  .intro {
    margin-top: var(--space-4);
    font-size: var(--text-md);
  }

  .actions {
    margin-top: var(--space-6);
  }

  .stat-grid {
    margin-top: var(--space-6);
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: var(--space-3);
    list-style: none;
    padding: 0;
  }

  .stat {
    text-align: center;
    padding: var(--space-4);
    box-shadow: none;
  }

  .stat strong {
    display: block;
    font-size: var(--text-xl);
    color: var(--text);
    font-variant-numeric: tabular-nums;
    letter-spacing: -0.01em;
  }

  .profile-aside {
    display: grid;
    gap: var(--space-4);
    align-content: start;
  }

  .avatar {
    width: 100%;
    max-width: 20rem;
    border-radius: 1rem;
    border: 1px solid var(--line);
  }

  .contact-list {
    list-style: none;
    padding: 0;
    display: grid;
    gap: var(--space-3);
  }

  .contact-list li {
    display: grid;
    gap: var(--space-1);
  }

  .contact-list span {
    color: var(--text-muted);
    font-size: var(--text-sm);
  }

  .projects-heading-row {
    justify-content: space-between;
    align-items: center;
  }

  .value-grid,
  .projects-grid,
  .skills-grid,
  .education-grid {
    display: grid;
    gap: var(--space-4);
  }

  .value-grid {
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }

  .projects-grid {
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }

  .skills-grid,
  .education-grid {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .value-card h3,
  .project-card h3 {
    margin-bottom: var(--space-3);
  }

  .project-card {
    display: grid;
    gap: var(--space-4);
    align-content: start;
    position: relative;
    overflow: hidden;
    isolation: isolate;
  }

  .project-card::before {
    content: "";
    position: absolute;
    inset: -1px;
    background: radial-gradient(
      480px circle at var(--spot-x, 50%) var(--spot-y, 0%),
      color-mix(in oklab, var(--primary-soft), transparent 30%),
      transparent 55%
    );
    z-index: -1;
    opacity: 0.75;
    transition: opacity 0.2s ease;
    pointer-events: none;
  }

  .project-card:hover::before {
    opacity: 1;
  }

  .project-siberind {
    border-color: color-mix(in oklab, var(--primary), var(--line) 60%);
    box-shadow: var(--shadow-2);
  }

  .project-header {
    display: grid;
    gap: var(--space-2);
  }

  .project-eyebrow {
    margin: 0;
    color: var(--primary);
    font-size: var(--text-sm);
    font-weight: 700;
  }

  .project-tagline {
    margin: 0;
    color: var(--text);
    font-weight: 600;
  }

  .project-impact strong {
    color: var(--text);
  }

  .tech-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .project-link {
    font-weight: 700;
    text-decoration: none;
    width: fit-content;
  }

  .project-link:hover {
    text-decoration: underline;
  }

  .process-grid {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: var(--space-4);
  }

  .process-item h3 {
    margin-bottom: var(--space-3);
  }

  .timeline-shell {
    position: relative;
    padding-left: 1rem;
  }

  .timeline-progress {
    position: absolute;
    left: 0.15rem;
    top: 0;
    bottom: 0;
    width: 0.35rem;
    border-radius: 999px;
    background: color-mix(in oklab, var(--line), transparent 35%);
    overflow: hidden;
  }

  .timeline-progress-fill {
    display: block;
    width: 100%;
    height: 100%;
    transform-origin: top;
    transform: scaleY(0);
    transition: transform 0.18s linear;
    background: linear-gradient(180deg, var(--primary), color-mix(in oklab, var(--success), var(--primary) 55%));
  }

  .tag-list {
    list-style: none;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3);
  }

  .skill-list {
    padding-left: 1.1rem;
    margin-top: var(--space-3);
    display: grid;
    gap: var(--space-2);
  }

  .faq-list {
    display: grid;
    gap: var(--space-4);
  }

  .faq-item summary {
